# EventOS Environment Variables
POSTGRES_USER=EventOS_user
POSTGRES_PASSWORD=EventOS_secret
POSTGRES_DB=EventOS_db
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql://EventOS_user:EventOS_secret@postgres:5432/EventOS_db

# External APIs
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Email Delivery Configuration
# mock: Never send real emails, log and print preview
# sendgrid: Require valid SENDGRID_API_KEY and send actual email
EMAIL_DELIVERY_MODE=mock
EMAIL_SENDGRID_FALLBACK_TO_MOCK=false

# SendGrid Settings (Required if EMAIL_DELIVERY_MODE=sendgrid)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=EventOS Operations

# Internal Settings
BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173
JWT_SECRET_KEY=your_super_secret_jwt_key
